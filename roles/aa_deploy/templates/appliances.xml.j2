<?xml version="1.0" encoding="UTF-8"?>
<!--
  Archiver Appliance cluster configuration

  This file must be identical across all appliances in the cluster.
  Each appliance uses ARCHAPPL_MYIDENTITY to determine which configuration to use.

  Generated by Ansible for {{ beamline_name }}
-->
<appliances>
{% for appliance in aa_cluster_appliances %}
  <appliance>
    <identity>{{ appliance.identity }}</identity>
    <cluster_inetport>{{ appliance.hostname }}:{{ appliance.cluster_inetport }}</cluster_inetport>
    <mgmt_url>https://{{ appliance.hostname }}/mgmt/bpl</mgmt_url>
    <engine_url>https://{{ appliance.hostname }}/engine/bpl</engine_url>
    <etl_url>https://{{ appliance.hostname }}/etl/bpl</etl_url>
    <retrieval_url>https://{{ appliance.hostname }}/retrieval/bpl</retrieval_url>
    <data_retrieval_url>https://{{ appliance.hostname }}/retrieval</data_retrieval_url>
  </appliance>
{% endfor %}
</appliances>
