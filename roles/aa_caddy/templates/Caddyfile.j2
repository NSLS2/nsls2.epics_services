# Archiver Appliance reverse proxy
# Generated by Ansible for {{ beamline_name }}

{{ inventory_hostname }} {
    tls {{ aa_caddy_tls_cert }} {{ aa_caddy_tls_key }}

    log

    handle /mgmt/* {
        reverse_proxy localhost:{{ mgmt_port }}
    }

    handle /engine/* {
        reverse_proxy localhost:{{ engine_port }}
    }

    handle /etl/* {
        reverse_proxy localhost:{{ etl_port }}
    }

    handle /retrieval/* {
        reverse_proxy localhost:{{ data_retrieval_port }}
    }
}
