# File /etc/systemd/system/save_restore.service
#
# After changes
#   sudo systemctl daemon-reload
#
# Start/status/stop
#   sudo systemctl start save_restore.service
#   sudo systemctl status save_restore.service
#   sudo systemctl stop save_restore.service
#
# Start when computer boots:
#   sudo systemctl enable save_restore.service
#

[Unit]
Description=save restore service
Documentation=https://github.com/ControlSystemStudio/phoebus/tree/master/services/save-and-restore
Wants=network-online.target
After=elasticsearch.service
Requires=elasticsearch.service

StartLimitIntervalSec=500
StartLimitBurst=5

[Service]
User={{ epics_services_account }}
Group={{ epics_services_account }}

Restart=on-failure
RestartSec=5s

Environment=JAVA_HOME={{ save_restore_java_home }}
Environment=PATH={{ save_restore_java_home }}/bin:/usr/bin:/usr/local/bin
Environment=SERVER=/opt/epics-tools/services/{{beamline_name}}/save_restore
Environment=PORT={{ save_restore_procServ_port }}

ExecStart=/usr/bin/procServ --foreground --noautorestart --name save-restore --chdir ${SERVER} --pidfile ${SERVER}/save-restore.pid --logfile ${SERVER}/console.log ${PORT} ./run-save-restore.sh

# Specifies the maximum file descriptor number that can be opened by this process
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
