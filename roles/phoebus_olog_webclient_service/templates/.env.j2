# {{ ansible_managed }}
#
# VITE build-time environment variables for the Phoebus Olog web client.
# These are baked into the JavaScript bundle at build time.

VITE_APP_BASE_URL="{{ phoebus_olog_url }}"
VITE_APP_ENDPOINT="{{ phoebus_olog_webclient_endpoint }}"
{% if phoebus_olog_webclient_websocket_url | default('') | length > 0 %}
VITE_APP_WEBSOCKET_BASE_URL="{{ phoebus_olog_webclient_websocket_url }}"
{% endif %}
{% if phoebus_olog_webclient_support_href | default('') | length > 0 %}
VITE_APP_SUPPORT_HREF="{{ phoebus_olog_webclient_support_href }}"
{% endif %}
{% if phoebus_olog_webclient_swagger_url | default('') | length > 0 %}
VITE_APP_SWAGGER_URL="{{ phoebus_olog_webclient_swagger_url }}"
{% endif %}
