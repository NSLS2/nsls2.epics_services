#!/bin/bash

# Startup script for the {{ aa_instance_name }} instance of the archiver appliance
# Generated by Ansible - do not edit manually

# We assume that we inherit the EPICS environment variables from something that calls this script
# However, if this is a init.d startup script, this is not going to be the case and we'll need to add them here.
# This includes setting up the LD_LIBRARY_PATH to include the JCA .so file.
###
#source /opt/local/setEPICSEnv.sh
export EPICS_CA_AUTO_ADDR_LIST=no
export EPICS_CA_ADDR_LIST="{{ aa_epics_ca_addr_list }}"
export EPICS_CA_MAX_ARRAY_BYTES=1100000
###

export JAVA_HOME="{{ aa_java_home }}"
export PATH=${JAVA_HOME}/bin:${PATH}

# Instance-specific JAVA_OPTS
export JAVA_OPTS="{{ aa_java_opts }}"

# Set up Tomcat home (RPM or tarball install)
export TOMCAT_HOME="{{ aa_tomcat_home }}"

# Set up the root folder of the individual Tomcat instances.
export ARCHAPPL_DEPLOY_DIR="{{ aa_deploy_location }}"

# Set appliance.xml and the identity of this appliance
export ARCHAPPL_APPLIANCES="{{ aa_deploy_location }}/appliances.xml"
export ARCHAPPL_MYIDENTITY="{{ aa_identity }}"

# If you have your own policies file, please change this line.
export ARCHAPPL_POLICIES="{{ aa_install_location }}/conf/policies.py"

# Set the location of short term and long term stores; this is necessary only if your policy demands it
###
export ARCHAPPL_SHORT_TERM_FOLDER="{{ aa_sts }}"
export ARCHAPPL_MEDIUM_TERM_FOLDER="{{ aa_mts }}"
export ARCHAPPL_LONG_TERM_FOLDER="{{ aa_lts }}"
###

# Instance-specific settings
export CATALINA_BASE="${ARCHAPPL_DEPLOY_DIR}/{{ aa_instance_name }}"
export INSTANCE_NAME="{{ aa_instance_name }}"

if [[ ! -d ${TOMCAT_HOME} ]]
then
    echo "Unable to determine the source of the tomcat distribution"
    exit 1
fi

if [[ ! -f ${ARCHAPPL_APPLIANCES} ]]
then
    echo "Unable to find appliances.xml at ${ARCHAPPL_APPLIANCES}"
    exit 1
fi

# Enable core dumps in case the JVM fails
###
#ulimit -c unlimited
###

function startTomcat() {
    export CATALINA_HOME=$TOMCAT_HOME
    export CATALINA_PID=${CATALINA_BASE}/pid
    echo "Starting tomcat instance ${INSTANCE_NAME} at location ${CATALINA_BASE}"

    ARCH=`uname -m`
    if [[ $ARCH == 'x86_64' || $ARCH == 'amd64' ]]
    then
      echo "Using 64 bit versions of libraries"
      export LD_LIBRARY_PATH=${CATALINA_BASE}/webapps/engine/WEB-INF/lib/native/linux-x86_64:${LD_LIBRARY_PATH}
    else
      echo "Using 32 bit versions of libraries"
      export LD_LIBRARY_PATH=${CATALINA_BASE}/webapps/engine/WEB-INF/lib/native/linux-x86:${LD_LIBRARY_PATH}
    fi

    # Set up classpath for Tomcat
    CLASSPATH="${CATALINA_HOME}/bin/bootstrap.jar:${CATALINA_HOME}/bin/tomcat-juli.jar"

    # Start Tomcat using Java directly (RHEL RPM doesn't include catalina.sh)
    ${JAVA_HOME}/bin/java \
        -Djava.util.logging.config.file=${CATALINA_BASE}/conf/logging.properties \
        -Djava.util.logging.manager=org.apache.juli.ClassLoaderLogManager \
        ${JAVA_OPTS} \
        -Djava.endorsed.dirs= \
        -classpath ${CLASSPATH} \
        -Dcatalina.base=${CATALINA_BASE} \
        -Dcatalina.home=${CATALINA_HOME} \
        -Djava.io.tmpdir=${CATALINA_BASE}/temp \
        org.apache.catalina.startup.Bootstrap start \
        >> ${CATALINA_BASE}/logs/catalina.out 2>&1 &

    echo $! > ${CATALINA_PID}
    echo "Started Tomcat with PID: $(cat ${CATALINA_PID})"
}

function stopTomcat() {
    export CATALINA_HOME=$TOMCAT_HOME
    export CATALINA_PID=${CATALINA_BASE}/pid
    echo "Stopping tomcat instance ${INSTANCE_NAME} at location ${CATALINA_BASE}"

    if [[ -f ${CATALINA_PID} ]]; then
        PID=$(cat ${CATALINA_PID})
        echo "Sending shutdown signal to PID: $PID"

        # Try graceful shutdown first
        ${JAVA_HOME}/bin/java \
            -Djava.util.logging.config.file=${CATALINA_BASE}/conf/logging.properties \
            -Djava.util.logging.manager=org.apache.juli.ClassLoaderLogManager \
            -classpath ${CATALINA_HOME}/bin/bootstrap.jar:${CATALINA_HOME}/bin/tomcat-juli.jar \
            -Dcatalina.base=${CATALINA_BASE} \
            -Dcatalina.home=${CATALINA_HOME} \
            org.apache.catalina.startup.Bootstrap stop 60

        # Wait for process to exit
        for i in {1..60}; do
            if ! kill -0 $PID 2>/dev/null; then
                echo "Tomcat stopped gracefully"
                rm -f ${CATALINA_PID}
                return 0
            fi
            sleep 1
        done

        # Force kill if still running
        echo "Forcing shutdown of PID: $PID"
        kill -9 $PID 2>/dev/null || true
        rm -f ${CATALINA_PID}
    else
        echo "PID file not found at ${CATALINA_PID}"
    fi
}

# See how we were called.
case "$1" in
  start)
	startTomcat
	;;
  stop)
	stopTomcat
	;;
  restart)
	stopTomcat
	startTomcat
	;;
  *)
	echo $"Usage: $0 {start|stop|restart}"
	exit 2
esac
