# File /etc/systemd/system/{{ beamline_name }}_phoebus_olog_webclient.service
#
# After changes
#   sudo systemctl daemon-reload
#
# Start/status/stop
#   sudo systemctl start {{ beamline_name }}_phoebus_olog_webclient.service
#   sudo systemctl status {{ beamline_name }}_phoebus_olog_webclient.service
#   sudo systemctl stop {{ beamline_name }}_phoebus_olog_webclient.service
#
# Start when computer boots:
#   sudo systemctl enable {{ beamline_name }}_phoebus_olog_webclient.service
#

[Unit]
Description=phoebus olog webclient service
Documentation=https://olog.readthedocs.io/en/latest/
Wants=network-online.target
After={{ beamline_name }}_phoebus_olog.service
Requires={{ beamline_name }}_phoebus_olog.service

StartLimitIntervalSec=500
StartLimitBurst=5

[Service]
User={{ epics_services_account }}
Group={{ epics_services_account }}

Restart=on-failure
RestartSec=5s

Environment=SERVER={{ phoebus_olog_webclient_project_path }}
Environment=PROC_PORT={{ olog_webclient_procServ_port }}

ExecStart=/usr/bin/procServ --foreground --noautorestart --name phoebus_olog_webclient --chdir ${SERVER} --pidfile ${SERVER}/olog_webclient.pid --logfile ${SERVER}/console.log ${PROC_PORT} ./run-phoebus-olog-webclient.sh

# Specifies the maximum file descriptor number that can be opened by this process
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
