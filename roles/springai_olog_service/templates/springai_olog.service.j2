# File /etc/systemd/system/springai_olog.service
#
# After changes
#   sudo systemctl daemon-reload
#
# Start/status/stop
#   sudo systemctl start springai_olog.service
#   sudo systemctl status springai_olog.service
#   sudo systemctl stop springai_olog.service
#
# Start when computer boots:
#   sudo systemctl enable springai_olog.service
#

[Unit]
Description=SpringAI Olog semantic search service
Documentation=https://github.com/alexariv/SpringAI
Wants=network-online.target
After=elasticsearch.service ollama.service

StartLimitIntervalSec=500
StartLimitBurst=5

[Service]
User={{ epics_services_account }}
Group={{ epics_services_account }}

Restart=on-failure
RestartSec=5s

Environment=JAVA_HOME={{ java_home }}
Environment=PATH={{ java_home }}/bin:/usr/bin:/usr/local/bin
Environment=SERVER={{ springai_olog_install_dir }}
Environment=PORT={{ springai_olog_procServ_port }}

ExecStart={{ procserv_path | default('/usr/bin/procServ') }} --foreground --noautorestart --name springai_olog --chdir ${SERVER} --pidfile ${SERVER}/springai_olog.pid --logfile ${SERVER}/console.log ${PORT} ./run-springai-olog.sh

# Specifies the maximum file descriptor number that can be opened by this process
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
