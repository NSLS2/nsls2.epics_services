# File /etc/systemd/system/channelfinder.service
#
# After changes
#   sudo systemctl daemon-reload
#
# Start/status/stop
#   sudo systemctl start channelfinder.service
#   sudo systemctl status channelfinder.service
#   sudo systemctl stop channelfinder.service
#
# Start when computer boots:
#   sudo systemctl enable channelfinder.service
#

[Unit]
Description=ChannelFinder service
Documentation=https://github.com/ChannelFinder/ChannelFinderService
Wants=network-online.target
After=elasticsearch.service

StartLimitIntervalSec=500
StartLimitBurst=5

[Service]
User={{ epics_services_account }}
Group={{ epics_services_account }}

Restart=on-failure
RestartSec=5s

Environment=JAVA_HOME={{ cf_java_home }}
Environment=PATH={{ cf_java_home }}/bin:/usr/bin:/usr/local/bin
Environment=SERVER={{ channelfinder_install_dir }}
Environment=PORT={{ cf_procServ_port }}

ExecStart=/usr/bin/procServ --foreground --noautorestart --name cf --chdir ${SERVER} --pidfile ${SERVER}/cf.pid --logfile ${SERVER}/console.log ${PORT} ./run-cf.sh

# Specifies the maximum file descriptor number that can be opened by this process
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
