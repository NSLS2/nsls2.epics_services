# File /etc/systemd/system/{{beamline_name}}phoebus_server.service
#
# After changes
#   sudo systemctl daemon-reload
#
# Start/status/stop
#   sudo systemctl start {{ beamline_name }}_phoebus_server.service
#   sudo systemctl status {{ beamline_name }}_phoebus_server.service
#   sudo systemctl stop {{ beamline_name }}_phoebus_server.service
#
# Start when computer boots:
#   sudo systemctl enable {{ beamline_name }}_phoebus_server.service
#

[Unit]
Description=alarm service
Documentation=https://github.com/ChannelFinder/ChannelFinderService
Wants=network-online.target
After={{ beamline_name }}_elastic.service

StartLimitIntervalSec=500
StartLimitBurst=5

[Service]
User={{ epics_services_account }}
Group={{ epics_services_account }}

Restart=on-failure
RestartSec=5s

Environment=JAVA_HOME={{ cf_java_home }}
Environment=PATH={{ cf_java_home }}/bin:/usr/bin:/usr/local/bin
Environment=SERVER=/opt/epics-tools/services/{{beamline_name}}/cf
Environment=PORT={{ cf_procServ_port }}

ExecStart=/usr/bin/procServ --foreground --noautorestart --name cf --chdir ${SERVER} --pidfile ${SERVER}/cf.pid --logfile ${SERVER}/console.log ${PORT} ./run-cf.sh

# Specifies the maximum file descriptor number that can be opened by this process
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
